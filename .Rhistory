)
m1 <- vglm(
cbind(y1, y2, y3) ~ Condition,
family = cumulative(link = "logitlink", parallel = TRUE),
data = d
)
tab <- as.data.frame(anova(m0, m1, type = "I", test = "LRT"))
## We expect 2 rows (m0 then m1); if not, fail fast with useful info
if (nrow(tab) < 2) {
stop("Unexpected anova table shape. Columns are: ",
paste(names(tab), collapse = ", "))
}
## Identify Df column (VGAM typically provides it)
df_col <- intersect(c("Df", "df"), names(tab))[1]
if (is.na(df_col)) {
stop("Could not find a Df column in anova table. Columns are: ",
paste(names(tab), collapse = ", "))
}
## p-value column: anything with 'Pr' in the name
p_candidates <- grep("Pr", names(tab), value = TRUE)
p_col <- if (length(p_candidates) >= 1) p_candidates[1] else NA_character_
## statistic column: first numeric column that is not Df and not a p-value column
numeric_cols <- names(tab)[vapply(tab, is.numeric, logical(1))]
stat_candidates <- setdiff(numeric_cols, c(df_col, p_candidates))
stat_col <- if (length(stat_candidates) >= 1) stat_candidates[1] else NA_character_
## Fallbacks if naming is odd
if (is.na(stat_col)) {
## use first numeric column that isn't Df
stat_candidates <- setdiff(numeric_cols, df_col)
if (length(stat_candidates) >= 1) stat_col <- stat_candidates[1]
}
if (is.na(p_col)) {
## use last numeric column as a last resort (often p-value)
if (length(numeric_cols) >= 1) p_col <- tail(numeric_cols, 1)
}
## Final validation
if (is.na(stat_col) || is.na(p_col)) {
stop("Could not identify statistic/p-value columns. Columns are: ",
paste(names(tab), collapse = ", "))
}
data.frame(
contrast  = paste(a, "vs", b),
statistic = unname(tab[2, stat_col]),
df        = unname(tab[2, df_col]),
p_value   = unname(tab[2, p_col])
)
}
pairwise_lrt <- function(dat, a, b) {
## dat must contain: Condition, y1, y2, y3
d <- dat %>%
filter(Condition %in% c(a, b)) %>%
mutate(
Condition = droplevels(Condition),
Condition = relevel(Condition, ref = b)
)
m0 <- vglm(
cbind(y1, y2, y3) ~ 1,
family = cumulative(link = "logitlink", parallel = TRUE),
data = d
)
m1 <- vglm(
cbind(y1, y2, y3) ~ Condition,
family = cumulative(link = "logitlink", parallel = TRUE),
data = d
)
tab <- as.data.frame(anova(m0, m1, type = "I", test = "LRT"))
## We expect 2 rows (m0 then m1); if not, fail fast with useful info
if (nrow(tab) < 2) {
stop("Unexpected anova table shape. Columns are: ",
paste(names(tab), collapse = ", "))
}
## Identify Df column (VGAM typically provides it)
df_col <- intersect(c("Df", "df"), names(tab))[1]
if (is.na(df_col)) {
stop("Could not find a Df column in anova table. Columns are: ",
paste(names(tab), collapse = ", "))
}
## p-value column: anything with 'Pr' in the name
p_candidates <- grep("Pr", names(tab), value = TRUE)
p_col <- if (length(p_candidates) >= 1) p_candidates[1] else NA_character_
## statistic column: first numeric column that is not Df and not a p-value column
numeric_cols <- names(tab)[vapply(tab, is.numeric, logical(1))]
stat_candidates <- setdiff(numeric_cols, c(df_col, p_candidates))
stat_col <- if (length(stat_candidates) >= 1) stat_candidates[1] else NA_character_
## Fallbacks if naming is odd
if (is.na(stat_col)) {
## use first numeric column that isn't Df
stat_candidates <- setdiff(numeric_cols, df_col)
if (length(stat_candidates) >= 1) stat_col <- stat_candidates[1]
}
if (is.na(p_col)) {
## use last numeric column as a last resort (often p-value)
if (length(numeric_cols) >= 1) p_col <- tail(numeric_cols, 1)
}
## Final validation
if (is.na(stat_col) || is.na(p_col)) {
stop("Could not identify statistic/p-value columns. Columns are: ",
paste(names(tab), collapse = ", "))
}
data.frame(
contrast  = paste(a, "vs", b),
statistic = unname(tab[2, stat_col]),
df        = unname(tab[2, df_col]),
p_value   = unname(tab[2, p_col])
)
}
pw <- bind_rows(
pairwise_lrt(df_fit, "Edited", "ControlNoAgro"),
pairwise_lrt(df_fit, "Edited", "ControlEmptyVector"),
pairwise_lrt(df_fit, "ControlNoAgro", "ControlEmptyVector")
) %>%
mutate(p_adj_holm = p.adjust(p_value, method = "holm"))
pw
library(dplyr)
library(tidyr)
df_long <- df %>%
select(ID, Condition,
OneSeed,
TwoSeeds,
ThreeSeeds) %>%
pivot_longer(
cols = c(OneSeed, TwoSeeds, ThreeSeeds),
names_to = "phenotype",
values_to = "count"
) %>%
mutate(
phenotype = recode(
phenotype,
OneSeed   = "1",
TwoSeeds   = "2",
ThreeSeeds = "3"
),
phenotype = ordered(phenotype, levels = c("1", "2", "3"))
) %>%
group_by(ID) %>%
mutate(
total = sum(count),
prop  = ifelse(total > 0, count / total, NA_real_)
) %>%
ungroup()
df_long
df_cond <- df_long %>%
filter(!is.na(prop)) %>%
group_by(Condition, phenotype) %>%
summarise(
mean_prop = mean(prop),
se_prop   = sd(prop) / sqrt(n()),
.groups   = "drop"
)
df_cond
ggplot(df_cond, aes(x = Condition, y = mean_prop, fill = phenotype)) +
geom_col(width = 0.7, color = "black") +
geom_errorbar(
aes(
ymin = pmax(0, mean_prop - se_prop),
ymax = pmin(1, mean_prop + se_prop)
),
width = 0.2
) +
scale_y_continuous(labels = percent_format(), limits = c(0, 1)) +
labs(
x = NULL,
y = "Mean proportion across samples (± SE)",
fill = "Phenotype"
) +
theme_classic(base_size = 12)
