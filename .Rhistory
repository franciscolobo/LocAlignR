data = centroids,
aes(x = Dim1, y = Dim2, label = label),
inherit.aes = FALSE,
size = 5,
fontface = "bold",
show.legend = FALSE
) +
scale_color_npg()+
labs(
title = title_text,
x = "Component 1",
y = "Component 2",
color = "Digit"
) +
theme_minimal(base_size = 12)
}
compute_centroids <- function(df) {
df %>%
group_by(label) %>%
summarize(
Dim1 = median(Dim1),
Dim2 = median(Dim2),
.groups = "drop"
)
}
