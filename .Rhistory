library(readxl)
library(ggplot2)
library(ordinal)     # clm (cumulative link model)
library(emmeans)     # estimated marginal means / contrasts
library(sandwich)    # robust vcov estimators
library(lmtest)      # coeftest / waldtest
library(tidyr)
library(dplyr)
df <- read_excel("~/Projects/Francisco/test/dummy_dataset.xlsx")
df_long <- df %>%
select(ID, Condition, NumberOfPods,
OneSeed, TwoSeeds, ThreeSeeds) %>%
pivot_longer(
cols = c(OneSeed, TwoSeeds, ThreeSeeds),
names_to = "category",
values_to = "count"
) %>%
mutate(
category = recode(category,
OneSeed   = "1",
TwoSeeds   = "2",
ThreeSeeds = "3"),
category = ordered(category, levels = c("1", "2", "3"))
) %>%
group_by(ID) %>%
mutate(
prop = count / sum(count)  # should equal count / Number_of_sets if consistent
) %>%
ungroup()
library(VGAM)
library(lmtest)
## Ensure desired reference level for Condition
df$Condition <- relevel(factor(df$Condition), ref = "ControlEmptyVector")
## Create a wide response of proportions for vglm
df_resp <- df %>%
transmute(
ID,
Condition = relevel(factor(Condition), ref = "ControlEmptyVector"),
w = NumberOfPods,
p1 = OneSeed   / NumberOfPods,
p2 = TwoSeeds   / NumberOfPods,
p3 = ThreeSeeds / NumberOfPods
)
df_fit <- df %>%
transmute(
ID,
Condition = relevel(factor(Condition), ref = "ControlEmptyVector"),
y1 = OneSeed,
y2 = TwoSeeds,
y3 = ThreeSeeds
)
## Optional sanity checks
stopifnot(all(df_fit$y1 >= 0, df_fit$y2 >= 0, df_fit$y3 >= 0))
stopifnot(all(df_fit$y1 == floor(df_fit$y1),
df_fit$y2 == floor(df_fit$y2),
df_fit$y3 == floor(df_fit$y3)))
## Drop samples with zero total, if any
df_fit <- df_fit %>% filter((y1 + y2 + y3) > 0)
pairwise_lrt <- function(dat, a, b) {
## dat must contain: Condition, y1, y2, y3
d <- dat %>%
filter(Condition %in% c(a, b)) %>%
mutate(
Condition = droplevels(Condition),
Condition = relevel(Condition, ref = b)
)
m0 <- vglm(
cbind(y1, y2, y3) ~ 1,
family = cumulative(link = "logitlink", parallel = TRUE),
data = d
)
m1 <- vglm(
cbind(y1, y2, y3) ~ Condition,
family = cumulative(link = "logitlink", parallel = TRUE),
data = d
)
## Likelihood ratio test (LRT) for nested vglm models
aov_tab <- anova(m0, m1, type = "I", test = "LRT")
## Coerce to data.frame for stable indexing
tab <- as.data.frame(aov_tab)
## Second row corresponds to the comparison (m1 vs m0)
## VGAM typically uses these column names under test="LRT"
stat_col <- intersect(c("LRT", "Chisq"), names(tab))[1]
p_col    <- intersect(c("Pr(>Chi)", "Pr(>Chisq)", "Pr(>LRT)"), names(tab))[1]
data.frame(
contrast  = paste(a, "vs", b),
statistic = tab[2, stat_col],
df        = tab[2, "Df"],
p_value   = tab[2, p_col]
)
}
library(dplyr)
pw <- bind_rows(
pairwise_lrt(df_fit, "Edited", "ControlNoAgro"),
pairwise_lrt(df_fit, "Edited", "ControlEmptyVector"),
pairwise_lrt(df_fit, "ControlNoAgro", "ControlEmptyVector")
) %>%
mutate(p_adj_holm = p.adjust(p_value, method = "holm"))
