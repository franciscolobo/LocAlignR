# Minimal example: PCA, t-SNE, and UMAP using keras3 (MNIST)
#
# Dataset:
#   keras3::dataset_mnist()
#   - 70,000 samples
#   - 784 features per sample (28x28 pixels)
#
# This script:
#   1. Loads MNIST via keras3
#   2. Reshapes images into vectors
#   3. Subsets and scales the data
#   4. Computes PCA, t-SNE, UMAP
#   5. Plots results
# -----------------------------
# 0. Install packages if needed
# -----------------------------
# install.packages(c("ggplot2", "Rtsne", "uwot", "keras3"))
library(ggplot2)
library(ggrepel)
library(dplyr)
library(Rtsne)
library(uwot)
library(keras3)
# -----------------------------
# 1. Load dataset (keras3)
# -----------------------------
mnist <- dataset_mnist()
x_train <- mnist$train$x
y_train <- mnist$train$y
# -----------------------------
# 2. Reshape images into vectors
# -----------------------------
# Convert 28x28 images into 784-length vectors
n_samples_total <- dim(x_train)[1]
X <- array_reshape(x_train, c(n_samples_total, 28 * 28))
y <- y_train
# -----------------------------
# 3. Subset and scale
# -----------------------------
set.seed(42)
n_subset <- 10000
idx <- sample(seq_len(nrow(X)), size = n_subset)
X_sub <- X[idx, ]
y_sub <- y[idx]
# Normalize pixel values
X_sub <- X_sub / 255
# Identify zero-variance columns BEFORE scaling
vars <- apply(X_sub, 2, var)
X_filtered <- X_sub[, vars > 0, drop = FALSE]
# Scale only the retained columns
X_scaled <- scale(X_filtered)
# Safety check
stopifnot(all(is.finite(X_scaled)))
cat("Subset shape:", dim(X_scaled), "\n")
# -----------------------------
# 4. PCA
# -----------------------------
pca_res <- prcomp(X_filtered, center = FALSE, scale. = FALSE)
pca_df <- data.frame(
Dim1 = pca_res$x[, 1],
Dim2 = pca_res$x[, 2],
label = factor(y_sub)
)
# -----------------------------
# 5. t-SNE
# -----------------------------
set.seed(42)
tsne_res <- Rtsne(
X_scaled,
dims = 2,
perplexity = 30,
pca = TRUE,
check_duplicates = FALSE,
verbose = TRUE
)
tsne_df <- data.frame(
Dim1 = tsne_res$Y[, 1],
Dim2 = tsne_res$Y[, 2],
label = factor(y_sub)
)
# -----------------------------
# 6. UMAP
# -----------------------------
set.seed(42)
umap_res <- umap(
X_scaled,
n_components = 2,
n_neighbors = 15,
min_dist = 0.1,
verbose = TRUE
)
umap_df <- data.frame(
Dim1 = umap_res[, 1],
Dim2 = umap_res[, 2],
label = factor(y_sub)
)
# -----------------------------
# 7. Plot helper
# -----------------------------
plot_embedding <- function(df, title_text) {
centroids <- compute_centroids(df)
ggplot(df, aes(x = Dim1, y = Dim2, color = label)) +
geom_point(size = 1.2, alpha = 0.8) +
geom_text_repel(
data = centroids,
aes(x = Dim1, y = Dim2, label = label),
inherit.aes = FALSE,
size = 5,
fontface = "bold",
show.legend = FALSE
) +
scale_color_npg()+
labs(
title = title_text,
x = "Component 1",
y = "Component 2",
color = "Digit"
) +
theme_minimal(base_size = 12)
}
compute_centroids <- function(df) {
df %>%
group_by(label) %>%
summarize(
Dim1 = median(Dim1),
Dim2 = median(Dim2),
.groups = "drop"
)
}
print(plot_embedding(pca_df, "PCA on MNIST (keras3)"))
print(plot_embedding(tsne_df, "t-SNE on MNIST (keras3)"))
print(plot_embedding(umap_df, "UMAP on MNIST (keras3)"))
