# ============================================================================
# LocAlignR Build Configuration
# ============================================================================
# Copy this file to .env and customize for your environment
# Source it before running builds: source .env

# ----------------------------------------------------------------------------
# SSL Certificate Configuration (for corporate proxy/HTTPS inspection)
# ----------------------------------------------------------------------------
# Path to your corporate CA bundle (PEM format)
# If you don't have HTTPS inspection, leave this commented out
# export CORPORATE_CA_BUNDLE="/path/to/corporate-ca-bundle.pem"

# Alternative: Set these if you prefer individual cert files
# export REQUESTS_CA_BUNDLE="/path/to/corporate-ca.pem"
# export SSL_CERT_FILE="/path/to/corporate-ca.pem"

# ----------------------------------------------------------------------------
# Anaconda.org Authentication
# ----------------------------------------------------------------------------
# Get your token from: https://anaconda.org/<username>/settings/access
# Recommended for automation and CI/CD
# export ANACONDA_API_TOKEN="your-token-here"

# Alternative: Use interactive login
# Run: anaconda login

# ----------------------------------------------------------------------------
# Build Configuration (optional overrides)
# ----------------------------------------------------------------------------
# Uncomment to override defaults

# Custom build environment name
# export BUILD_ENV="localignr-build"

# Custom test environment name
# export TEST_ENV="localignr-test"

# Package name
# export PACKAGE_NAME="r-localignr"

# R package name (for testing)
# export R_PACKAGE_NAME="LocAlignR"

# ----------------------------------------------------------------------------
# How to get your corporate CA certificate
# ----------------------------------------------------------------------------
# On macOS:
#   1. Open Keychain Access
#   2. Find your corporate root CA in System or login keychain
#   3. Right-click → Export → Save as .pem
#
# On Windows with Git Bash:
#   1. Run: openssl s_client -connect anaconda.org:443 -showcerts
#   2. Copy the certificate chain to a .pem file
#
# Or extract from system:
#   Python: python -c "import ssl; print(ssl.get_default_verify_paths())"
#   OpenSSL: openssl version -d
